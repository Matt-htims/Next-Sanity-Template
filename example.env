# Sanity webhook auth secret for /api/sanity/revalidate
# Generate with: openssl rand -hex 32
SANITY_REVALIDATE_SECRET=

# Sanity draft preview token
# Generate with: openssl rand -hex 32
# Share preview links as: https://yourdomain.com/your-slug?preview=TOKEN
SANITY_PREVIEW_TOKEN=

# Public-facing preview token used by Sanity Studio preview pane and "Open preview" button.
# Must match SANITY_PREVIEW_TOKEN exactly.
NEXT_PUBLIC_PREVIEW_TOKEN=

# Base URL of the frontend (no trailing slash) — used by Sanity Studio preview
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# Sanity API read token (viewer role) — required for draft preview
# Create at: https://sanity.io/manage → project → API → Tokens
SANITY_API_READ_TOKEN=
