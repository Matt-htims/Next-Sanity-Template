# Sanity Studio deploy tool (optional)
# Vercel deploy hook URL used by the custom Studio Deploy tool.
NEXT_PUBLIC_SANITY_STUDIO_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/<your-deploy-hook-id>

# Optional button label shown in Sanity Studio.
NEXT_PUBLIC_SANITY_STUDIO_DEPLOY_LABEL=Deploy Production Site
